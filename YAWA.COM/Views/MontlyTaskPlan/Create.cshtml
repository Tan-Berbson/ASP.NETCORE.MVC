@model MontlyTask
<div class="content">
    <h2>Create New Monthly Task</h2>
    <hr />
        <div class="row">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="form-group mb-2">
                    <label asp-for="DailyTaskName">TaskName</label>
                    <input asp-for="DailyTaskName" type="text" class="form-control" />
                    <span asp-validation-for="DailyTaskName"></span>
                </div>

                <div class="form-group mb-2">
                    <label asp-for="StartDate">StartDate</label>
                    <input asp-for="StartDate" type="date" class="form-control" />
                    <span asp-validation-for="StartDate"></span>
                </div>

                <div class="form-group mb-2">
                    <label asp-for="EndDate">EndDate</label>
                    <input asp-for="EndDate" type="date" class="form-control" />
                    <span asp-validation-for="EndDate"></span>
                </div>

                 <div class="form-group mb-2">
                    <label asp-for="MontlyTaskCategory">MontlyTaskCategory</label>
                    <input asp-for="MontlyTaskCategory" type="text" class="form-control" />
                    <span asp-validation-for="MontlyTaskCategory"></span>
                </div>

                <div class="form-group mb-2">
                    <label asp-for="TaskStatus">TaskStatus</label>
                    <select class="form-control" asp-for="TaskStatus">
                        <option value="Inprogress">Inprogress</option>
                        <option value="Complete">Complete</option>
                    </select>
                </div>

               

                <div class="form-group d-grid mb-2">
                    <a asp-action="Index" class="btn btn-primary">Back</a>
                </div>
                <div class="form-group d-grid mb-2">
                    <button type="submit" class="btn btn-success">Create</button>
                </div>
            </form>
        </div>
</div>