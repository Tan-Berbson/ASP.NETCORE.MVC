@model LessonPlanner
<div class="content">
    <div class="row">
        <h2>Edit Lesson</h2>
        <hr />
        <form asp-action="Update" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div class="form-group  mb-2 ">              
                <input asp-for="LessonTittle" class="form-control" type="hidden"/>
            </div>
            <div class="form-group mb-2 ">
                <label asp-for="LessonName">LessonName</label>
                <input asp-for="LessonName" class="form-control" type="text" />
                <span asp-validation-for="LessonName"></span>
            </div>
            <div class="form-group mb-2 ">
                <label asp-for="LessonDescription">LessonDescription</label>
                <input asp-for="LessonDescription" class="form-control" type="text" />
                <span asp-validation-for="LessonDescription"></span>
            </div>
            <div class="form-group mb-2">
                <label asp-for="LessonStatus">LessonStatus</label>
                <select asp-for="LessonStatus" class="form-control">
                    <option value="Inprogress">Inprogress</option>
                    <option value="Complete">Complete</option>
                </select>
            </div>
            <div class="d-grid mb-2">
                <a asp-action="Index" class="btn btn-primary">Cancel</a>
            </div>
            <div class="d-grid mb-2">
                <button type="submit" class="btn btn-success">Update</button>
            </div>
        </form>
    </div>
</div>