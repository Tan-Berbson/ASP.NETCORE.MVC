@model LessonPlanner
<div class="content">
    <div class="row">
        <form asp-action="ConfirmedDelete" asp-route-id ="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <div class="alert alert-warning">
                <p>are you sure you want to delete this lesson @Model.LessonTittle?</p>
               

            </div>
            <div class="mb-2 d-grid">
                <a asp-action="Index" class="btn btn-primary">Cancel</a>
            </div>
            <div class="mb-2 d-grid">
                <button type="submit" class="btn btn-danger">Delete</button>
            </div>
        </form>
    </div>
</div>