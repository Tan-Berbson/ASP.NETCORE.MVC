@model IEnumerable<LessonPlanner>
@{
    var titles = ViewData["Titles"] as IEnumerable<string>;
    var selectedTitle = ViewData["SelectedTitle"] as string;
}
<div class="content">
    <h2>Lesson Planner DashBoard</h2>
    <hr />
    <div class="row">
        <div>
            @if(TempData["Message"] != null)
            {
                <div class="alert alert-success alert-dismissible  fade-show font-monospace" role="alert">
                    @TempData["Message"]
                    <button type="button" class="btn btn-close" data-bs-dismissable="alert"></button>
                </div>
            }
            <div class="col-12 mb-3">
                <form method="get" class="row g-2 align-items-end">
                    <div class="col-md-10">
                        <label for="titleFilter" class="form-label">Filter by Title</label>
                        <select id="titleFilter" name="title" class="form-select">
                          
                            @if(titles != null)
                            {
                                @foreach(var t in titles)
                                {
                                    if(t == selectedTitle)
                                    {
                                        <option value="@t" selected>@t</option>
                                    }
                                    else
                                    {
                                        <option value="@t">@t</option>
                                    }
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-info w-100">Filter</button>
                    </div>
                </form>
            </div>
            <div class="col-12 mb-2">
                <a asp-action="Create" class="btn btn-primary">Create</a>
            </div>
            <div class="col-12"> 
                <table class="table table-bordered table-hover table-sm font-monospace">
                    <colgroup>
                        <col class="col-3" />
                        <col class="col-6" />
                        <col class="col-3" />

                    </colgroup>
                    <thead class="bg-danger text-dark">
                        <tr>
                            <th>LessonName</th>
                            <th>Description</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    @foreach(var item in Model)
                    {
                        <tr>
                            <td>@item.LessonName</td>
                            <td>@item.LessonDescription</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id"  class="btn btn-primary">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">Delete</a>
                            </td>
                        </tr>
                    }

                </table>

            </div>
        </div>
    </div>

</div>