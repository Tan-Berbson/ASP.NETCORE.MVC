@model LessonPlanner
<div class="content">
    <h2>
        Create Lesson
    </h2>
    <div class="row">
        @Html.AntiForgeryToken()

        <form asp-action="Create" method="post">
           <div class="form-group mb-3">
               <label asp-for="LessonTittle"> LessonTitle</label>
               <input asp-for="LessonTittle" type="text" class="form-control" />
               <span asp-validation-for="LessonTittle"></span>
           </div>
           <div class="form-group mb-3">
               <label asp-for="LessonName">LessonName</label>
               <input asp-for="LessonName" type="text" class="form-control" />
               <span asp-validation-for="LessonName"></span>
           </div>
            <div class="form-group mb-3">
               <label asp-for="LessonDescription">LessonDescription</label>
                <input asp-for="LessonDescription" type="text" class="form-control" />
                <span asp-validation-for="LessonDescription"></span>
           </div>
           <div class="form-group mb-2 d-grid">
               <a asp-action="Index" class="btn btn-primary">Cancel</a>
           </div>
           <div class="form-group d-grid mb-2">
               <button type="submit" class="btn btn-success">Create</button>

           </div>
            

       </form>

    </div>
</div>

